<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Entrepreneurship — SWAL Learn</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#060810;--border:#1a2235;--accent:#ff6b35;--accent2:#f7c948;--text:#e8edf5;--muted:#5a6a80;--card:#0f1520;--success:#00e676;--error:#ff4757;--warn:#ffd32a;}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;min-height:100vh}
    body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,107,53,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,107,53,.025) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0}
    nav{position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1rem 2rem;border-bottom:1px solid var(--border);background:rgba(6,8,16,.95);backdrop-filter:blur(16px)}
    .nav-logo{font-size:1.1rem;font-weight:800;text-decoration:none;color:var(--text)}.nav-logo span{color:var(--accent)}
    .nav-back{color:var(--muted);text-decoration:none;font-size:.82rem;font-family:'DM Mono',monospace;transition:color .2s;display:flex;align-items:center;gap:.3rem}.nav-back:hover{color:var(--accent)}
    .hero{position:relative;z-index:1;padding:4rem 2rem 2.5rem;max-width:960px;margin:0 auto;text-align:center}
    .course-badge{display:inline-flex;align-items:center;gap:.4rem;background:rgba(255,107,53,.08);border:1px solid rgba(255,107,53,.2);color:var(--accent);padding:.3rem .9rem;border-radius:999px;font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:1.5rem}
    .hero h1{font-size:clamp(2rem,5vw,3.2rem);font-weight:800;letter-spacing:-.03em;line-height:1.1;margin-bottom:1rem}
    .hero h1 em{font-style:normal;color:var(--accent)}
    .hero-desc{font-size:.95rem;color:var(--muted);line-height:1.7;font-family:'DM Mono',monospace;font-weight:300;max-width:600px;margin:0 auto 2rem}
    .hero-meta{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    .meta-pill{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:.45rem 1rem;font-size:.76rem;font-family:'DM Mono',monospace;color:var(--muted)}.meta-pill strong{color:var(--text)}
    .progress-wrap{max-width:960px;margin:2rem auto 2.5rem;padding:0 2rem;position:relative;z-index:1}
    .progress-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem}
    .progress-label{font-size:.75rem;font-family:'DM Mono',monospace;color:var(--muted)}
    .progress-score{font-size:.75rem;font-family:'DM Mono',monospace;color:var(--accent);font-weight:700}
    .progress-bar{height:6px;background:var(--border);border-radius:999px;overflow:hidden}
    .progress-fill{height:100%;background:linear-gradient(90deg,var(--accent2),var(--accent));border-radius:999px;width:0%;transition:width .8s cubic-bezier(.4,0,.2,1)}
    .lessons{max-width:960px;margin:0 auto;padding:0 2rem 5rem;position:relative;z-index:1}
    .module-header{margin:2.5rem 0 1rem;padding:.6rem 1rem;background:rgba(255,107,53,.05);border:1px solid rgba(255,107,53,.15);border-radius:10px;font-size:.75rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);font-family:'DM Mono',monospace}
    .lesson-card{background:var(--card);border:1px solid var(--border);border-radius:18px;margin-bottom:.9rem;overflow:hidden;transition:border-color .25s,opacity .25s}
    .lesson-card.locked{opacity:.45;pointer-events:none}
    .lesson-card.passed{border-color:rgba(0,230,118,.3)}
    .lesson-card.active-open{border-color:rgba(255,107,53,.3)}
    .lesson-header{display:flex;align-items:center;gap:1rem;padding:1.2rem 1.4rem;cursor:pointer;user-select:none;transition:background .15s}.lesson-header:hover{background:rgba(255,255,255,.02)}
    .lesson-num{width:38px;height:38px;border-radius:9px;background:rgba(255,107,53,.07);border:1px solid rgba(255,107,53,.2);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:var(--accent);font-family:'DM Mono',monospace;flex-shrink:0;transition:all .3s}
    .lesson-num.passed{background:rgba(0,230,118,.15);border-color:var(--success);color:var(--success)}
    .lesson-info{flex:1;min-width:0}
    .lesson-title{font-size:.95rem;font-weight:700;margin-bottom:.15rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .lesson-subtitle{font-size:.75rem;color:var(--muted);font-family:'DM Mono',monospace}
    .lesson-status{flex-shrink:0;display:flex;align-items:center;gap:.4rem}
    .lock-icon{font-size:.9rem;color:var(--muted)}
    .pass-badge{font-size:.7rem;font-weight:700;background:rgba(0,230,118,.12);border:1px solid rgba(0,230,118,.3);color:var(--success);padding:.2rem .5rem;border-radius:6px;font-family:'DM Mono',monospace}
    .score-badge{font-size:.7rem;font-weight:700;background:rgba(255,107,53,.08);border:1px solid rgba(255,107,53,.2);color:var(--accent);padding:.2rem .5rem;border-radius:6px;font-family:'DM Mono',monospace}
    .lesson-toggle{color:var(--muted);font-size:1.1rem;transition:transform .3s;flex-shrink:0}
    .lesson-card.active-open .lesson-toggle{transform:rotate(180deg)}
    .lesson-body{display:none;padding:0 1.5rem 1.5rem;border-top:1px solid var(--border)}
    .lesson-body.open{display:block}
    .lesson-body h3{font-size:.88rem;font-weight:700;margin:1.3rem 0 .5rem;color:var(--accent);text-transform:uppercase;letter-spacing:.05em;font-family:'DM Mono',monospace}
    .lesson-body p{font-size:.88rem;color:var(--muted);line-height:1.85;font-family:'DM Mono',monospace;font-weight:300;margin-bottom:.8rem}
    .lesson-body ul,.lesson-body ol{margin:.4rem 0 .9rem 1.1rem}
    .lesson-body ul li,.lesson-body ol li{font-size:.87rem;color:var(--muted);line-height:1.8;font-family:'DM Mono',monospace;font-weight:300;margin-bottom:.3rem}
    .lesson-body ul li::marker{color:var(--accent)}
    .lesson-body ol li::marker{color:var(--accent);font-weight:700}
    .lesson-body strong{color:var(--text);font-weight:700}
    .lesson-body em{color:var(--accent2);font-style:normal}
    .template-box{margin:1.4rem 0;background:rgba(247,201,72,.04);border:1px solid rgba(247,201,72,.2);border-radius:12px;padding:1.2rem 1.4rem}
    .template-title{font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent2);font-family:'DM Mono',monospace;margin-bottom:.8rem;display:flex;align-items:center;gap:.5rem}
    .template-body{font-family:'DM Mono',monospace;font-size:.82rem;color:var(--muted);line-height:1.9;white-space:pre-wrap}
    .glossary-box{margin:1.4rem 0 .8rem;background:rgba(255,107,53,.04);border:1px solid rgba(255,107,53,.15);border-radius:10px;padding:.9rem 1.1rem;font-family:'DM Mono',monospace;font-size:.8rem;color:var(--muted);line-height:1.9}
    .gls-title{color:var(--accent);font-weight:700;display:block;margin-bottom:.4rem;letter-spacing:.08em}
    .resources-box{margin:.6rem 0 1.2rem;background:rgba(0,230,118,.03);border:1px solid rgba(0,230,118,.15);border-radius:10px;padding:.9rem 1.1rem;font-family:'DM Mono',monospace;font-size:.8rem}
    .res-title{color:var(--success);font-weight:700;display:block;margin-bottom:.4rem;letter-spacing:.08em}
    .resources-box a{color:var(--success);text-decoration:none;opacity:.8}.resources-box a:hover{opacity:1}
    .africa-box{margin:1.2rem 0;background:rgba(247,201,72,.05);border:1px solid rgba(247,201,72,.2);border-radius:10px;padding:.9rem 1.1rem;font-family:'DM Mono',monospace;font-size:.82rem;color:var(--muted);line-height:1.8}
    .africa-title{color:var(--accent2);font-weight:700;display:block;margin-bottom:.35rem}
    .quiz-container{margin-top:2.2rem;border-radius:16px;overflow:hidden;border:1px solid rgba(255,107,53,.15);background:rgba(0,0,0,.25)}
    .quiz-header{padding:1.2rem 1.5rem;background:linear-gradient(135deg,rgba(255,107,53,.1),rgba(247,201,72,.05));border-bottom:1px solid rgba(255,107,53,.12)}
    .quiz-header-top{display:flex;align-items:center;gap:.8rem;margin-bottom:.5rem}
    .quiz-icon{font-size:1.3rem;flex-shrink:0}
    .quiz-title-wrap{flex:1}
    .quiz-eyebrow{font-size:.62rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);font-family:'DM Mono',monospace;margin-bottom:.15rem}
    .quiz-title{font-size:1rem;font-weight:800;color:var(--text)}
    .quiz-meta-row{display:flex;gap:.6rem;flex-wrap:wrap;align-items:center}
    .quiz-badge{background:rgba(255,107,53,.1);border:1px solid rgba(255,107,53,.2);color:var(--accent);font-size:.66rem;font-weight:700;font-family:'DM Mono',monospace;padding:.2rem .55rem;border-radius:6px}
    .quiz-pass-badge{background:rgba(255,211,42,.08);border:1px solid rgba(255,211,42,.25);color:var(--warn);font-size:.66rem;font-weight:700;font-family:'DM Mono',monospace;padding:.2rem .55rem;border-radius:6px}
    .quiz-timer{margin-left:auto;background:rgba(0,0,0,.3);border:1px solid var(--border);color:var(--muted);font-size:.66rem;font-weight:700;font-family:'DM Mono',monospace;padding:.2rem .55rem;border-radius:6px;display:flex;align-items:center;gap:.3rem}
    .quiz-questions{padding:1.3rem 1.5rem;display:flex;flex-direction:column;gap:1.6rem}
    .q-text{font-size:.89rem;font-weight:700;margin-bottom:.75rem;line-height:1.55;display:flex;gap:.65rem;align-items:flex-start;color:var(--text)}
    .q-num{flex-shrink:0;background:linear-gradient(135deg,var(--accent2),var(--accent));color:#060810;font-size:.65rem;font-weight:800;font-family:'DM Mono',monospace;padding:.18rem .45rem;border-radius:5px;margin-top:.15rem;letter-spacing:.04em}
    .q-options{display:grid;gap:.5rem}
    .q-option{padding:.7rem 1.05rem;border:1px solid var(--border);border-radius:10px;font-size:.84rem;font-family:'DM Mono',monospace;cursor:pointer;transition:all .18s;background:rgba(255,255,255,.018);color:var(--muted);display:flex;align-items:center;gap:.7rem}
    .q-option::before{content:'';width:15px;height:15px;border-radius:50%;border:1.5px solid var(--border);flex-shrink:0;transition:all .18s}
    .q-option:hover{border-color:rgba(255,107,53,.35);color:var(--text);background:rgba(255,107,53,.04)}
    .q-option:hover::before{border-color:rgba(255,107,53,.5)}
    .q-option.selected{border-color:rgba(255,107,53,.55);color:var(--text);background:rgba(255,107,53,.09)}
    .q-option.selected::before{background:var(--accent);border-color:var(--accent)}
    .q-option.correct{border-color:var(--success)!important;background:rgba(0,230,118,.12)!important;color:var(--success)!important;pointer-events:none}
    .q-option.correct::before{background:var(--success);border-color:var(--success)}
    .q-option.wrong{border-color:var(--error)!important;background:rgba(255,71,87,.1)!important;color:var(--error)!important;pointer-events:none}
    .q-option.wrong::before{background:var(--error);border-color:var(--error)}
    .q-option.reveal-correct{border-color:rgba(0,230,118,.4)!important;background:rgba(0,230,118,.06)!important;color:rgba(0,230,118,.75)!important;pointer-events:none}
    .q-option.reveal-correct::before{background:rgba(0,230,118,.5);border-color:rgba(0,230,118,.5)}
    .q-option.disabled{pointer-events:none}
    .q-feedback{font-size:.75rem;font-family:'DM Mono',monospace;margin-top:.4rem;padding:.3rem .65rem;border-radius:7px;display:none;font-weight:500}
    .q-feedback.show{display:block}
    .q-feedback.ok{color:var(--success);background:rgba(0,230,118,.08);border:1px solid rgba(0,230,118,.15)}
    .q-feedback.no{color:var(--error);background:rgba(255,71,87,.08);border:1px solid rgba(255,71,87,.15)}
    .quiz-actions{padding:.6rem 1.5rem 1.4rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
    .quiz-answered-count{font-size:.73rem;font-family:'DM Mono',monospace;color:var(--muted)}
    .quiz-answered-count span{color:var(--accent);font-weight:700}
    .quiz-submit-btn{padding:.7rem 1.8rem;background:linear-gradient(135deg,var(--accent2),var(--accent));border:none;border-radius:10px;color:#060810;font-family:'Syne',sans-serif;font-weight:800;font-size:.86rem;cursor:pointer;transition:opacity .2s,transform .15s;letter-spacing:.02em}
    .quiz-submit-btn:disabled{opacity:.3;cursor:not-allowed}
    .quiz-submit-btn:not(:disabled):hover{opacity:.88;transform:translateY(-1px)}
    .quiz-result{margin:0 1.5rem 1.5rem;border-radius:14px;padding:0;border:1px solid;overflow:hidden}
    .result-overlay{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity .35s ease}
    .result-overlay.show{opacity:1;pointer-events:auto}
    .result-overlay-bg{position:absolute;inset:0;background:rgba(6,8,16,.88);backdrop-filter:blur(14px)}
    .result-modal{position:relative;z-index:1;background:var(--card);border:1px solid var(--border);border-radius:22px;max-width:520px;width:100%;overflow:hidden;transform:scale(.92) translateY(20px);transition:transform .38s cubic-bezier(.34,1.56,.64,1);box-shadow:0 40px 120px rgba(0,0,0,.7)}
    .result-overlay.show .result-modal{transform:scale(1) translateY(0)}
    .rm-top{padding:2rem 2rem 1.4rem;text-align:center}
    .rm-top.pass{background:linear-gradient(180deg,rgba(0,230,118,.08) 0%,transparent 100%)}
    .rm-top.fail{background:linear-gradient(180deg,rgba(255,71,87,.07) 0%,transparent 100%)}
    .rm-icon{font-size:3.2rem;margin-bottom:.7rem;display:block;animation:rm-pop .5s cubic-bezier(.34,1.56,.64,1) .2s both}
    @keyframes rm-pop{from{transform:scale(0) rotate(-15deg)}to{transform:scale(1) rotate(0)}}
    .rm-label{font-size:.65rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;font-family:'DM Mono',monospace;margin-bottom:.3rem}
    .rm-label.pass{color:var(--success)}.rm-label.fail{color:var(--error)}
    .rm-verdict{font-size:1.6rem;font-weight:800;letter-spacing:-.03em;margin-bottom:.3rem}
    .rm-msg{font-size:.8rem;color:var(--muted);font-family:'DM Mono',monospace;font-weight:300;line-height:1.65}
    .rm-tier{display:inline-flex;align-items:center;gap:.4rem;padding:.3rem .8rem;border-radius:999px;font-size:.7rem;font-weight:700;font-family:'DM Mono',monospace;margin-top:.6rem;border:1px solid}
    .rm-tier.s{background:rgba(255,107,53,.1);border-color:rgba(255,107,53,.3);color:var(--accent)}
    .rm-tier.a{background:rgba(0,230,118,.1);border-color:rgba(0,230,118,.3);color:var(--success)}
    .rm-tier.b{background:rgba(247,201,72,.1);border-color:rgba(247,201,72,.3);color:var(--accent2)}
    .rm-tier.c{background:rgba(255,211,42,.08);border-color:rgba(255,211,42,.3);color:var(--warn)}
    .rm-tier.f{background:rgba(255,71,87,.08);border-color:rgba(255,71,87,.3);color:var(--error)}
    .rm-score-row{display:flex;align-items:center;justify-content:center;gap:1.8rem;padding:1.4rem 2rem;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
    .rm-stat{text-align:center}
    .rm-stat-val{font-size:1.6rem;font-weight:800;display:block;margin-bottom:.1rem}
    .rm-stat-val.pass{color:var(--success)}.rm-stat-val.fail{color:var(--error)}.rm-stat-val.neutral{color:var(--accent)}
    .rm-stat-label{font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-family:'DM Mono',monospace;color:var(--muted)}
    .rm-divider{width:1px;height:40px;background:var(--border)}
    .rm-gauge-wrap{padding:1.2rem 2rem;border-bottom:1px solid var(--border)}
    .rm-gauge-label{display:flex;justify-content:space-between;margin-bottom:.4rem;font-size:.72rem;font-family:'DM Mono',monospace}
    .rm-gauge-label span:first-child{color:var(--muted)}
    .rm-gauge-bar{height:10px;background:var(--border);border-radius:999px;overflow:hidden;position:relative}
    .rm-gauge-fill{height:100%;border-radius:999px;transition:width 1.2s cubic-bezier(.4,0,.2,1);width:0%}
    .rm-gauge-fill.pass{background:linear-gradient(90deg,#00bfa5,var(--success))}
    .rm-gauge-fill.fail{background:linear-gradient(90deg,#c62828,var(--error))}
    .rm-gauge-marker{position:absolute;top:-1px;bottom:-1px;width:2px;background:var(--warn);left:60%;border-radius:999px}
    .rm-gauge-marker::after{content:'60%';position:absolute;top:-18px;left:50%;transform:translateX(-50%);font-size:.58rem;color:var(--warn);font-family:'DM Mono',monospace;white-space:nowrap}
    .rm-breakdown{padding:1rem 2rem;border-bottom:1px solid var(--border)}
    .rm-breakdown-title{font-size:.65rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-family:'DM Mono',monospace;color:var(--muted);margin-bottom:.7rem}
    .rm-breakdown-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:.4rem}
    .rm-bq{display:flex;flex-direction:column;align-items:center;gap:.25rem}
    .rm-bq-num{font-size:.65rem;font-family:'DM Mono',monospace;color:var(--muted)}
    .rm-bq-dot{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.8rem;border:1px solid}
    .rm-bq-dot.ok{background:rgba(0,230,118,.12);border-color:rgba(0,230,118,.3)}
    .rm-bq-dot.no{background:rgba(255,71,87,.1);border-color:rgba(255,71,87,.3)}
    .rm-actions{padding:1.2rem 2rem;display:flex;gap:.7rem;flex-wrap:wrap}
    .rm-retry{flex:1;padding:.65rem 1rem;background:transparent;border:1px solid var(--border);border-radius:10px;color:var(--muted);font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;cursor:pointer;transition:all .2s;min-width:120px}
    .rm-retry:hover{border-color:var(--accent);color:var(--accent)}
    .rm-next{flex:2;padding:.65rem 1.2rem;background:linear-gradient(135deg,var(--success),#00bfa5);border:none;border-radius:10px;color:#060810;font-family:'Syne',sans-serif;font-weight:800;font-size:.84rem;cursor:pointer;transition:opacity .2s;min-width:160px}
    .rm-next:hover{opacity:.88}
    .rm-cert{flex:2;padding:.65rem 1.2rem;background:linear-gradient(135deg,var(--accent2),var(--accent));border:none;border-radius:10px;color:#060810;font-family:'Syne',sans-serif;font-weight:800;font-size:.84rem;cursor:pointer;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:.4rem;transition:opacity .2s}
    .rm-cert:hover{opacity:.88}
    .cert-banner{max-width:960px;margin:0 auto 5rem;padding:0 2rem;position:relative;z-index:1}
    .cert-box{background:linear-gradient(135deg,rgba(255,107,53,.08),rgba(247,201,72,.08));border:1px solid rgba(255,107,53,.2);border-radius:18px;padding:2rem;text-align:center}
    .cert-box.locked-cert{opacity:.4;pointer-events:none}
    .cert-box h3{font-size:1.2rem;font-weight:800;margin-bottom:.4rem}
    .cert-box p{font-size:.84rem;color:var(--muted);font-family:'DM Mono',monospace;margin-bottom:1.1rem}
    .cert-box a{display:inline-block;padding:.7rem 1.8rem;background:linear-gradient(135deg,var(--accent2),var(--accent));color:#060810;border-radius:8px;font-weight:700;text-decoration:none;font-size:.88rem}
    footer{border-top:1px solid var(--border);padding:2rem;text-align:center;font-size:.76rem;color:var(--muted);font-family:'DM Mono',monospace;position:relative;z-index:1}
    @media(max-width:600px){.hero{padding:3rem 1.2rem 2rem}.lessons,.progress-wrap,.cert-banner{padding-left:1.2rem;padding-right:1.2rem}.lesson-header{padding:1rem}.lesson-body{padding:0 1rem 1rem}.rm-score-row{gap:1rem}.rm-actions{flex-direction:column}}
  </style>
</head>
